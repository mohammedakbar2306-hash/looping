void prime(int p)
{
    int c;
    for(int i=1;i<=p;i++)
    {
        if(p%i==0)
        {
            c+=1;
        }
    }
    if(c==2)
    {
        cout<<"The given number is Prime number"<<endl;
    }
    else{
        cout<<"The given number is not a prime number"<<endl;
    }
}
int main()
{
    int p;
cout<<"Enter a number to check wheather it is prime number or not"<<endl;
cin>>p;
prime(p);

}
#include <iostream>
using namespace std;
void palindrome(int s)
{
    int temp=0,c=0,r;
    temp =s;
    while(s>0)
    {
       r=s%10;
       c=(c*10)+r;
       s/=10;
    }
    if(temp==c)
    {
        cout<<"The number is palindrome"<<endl;
    }
    else
    {
        cout<<"The number is not a palindrome"<<endl;
    }
}
int main()
{
    int s;
    cout<<"Enter a number to check it is a palindrome or not: " <<endl;
    cin>>s;
    palindrome(s);
}
void count(int a)
{
    int c=0;
    while(a>0)
    {
        a/=10;
        c+=1;
    }
    cout<<"The count is "<<c;
}
int main()
{
    int a;
    cout<<"Enter the number to count number of digits"<<endl;
    cin>>a;
    count(a);
}











